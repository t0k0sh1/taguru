{
  "name": "langchain-taguru",
  "version": "0.2.0",
  "description": "LangChain.js integration for the Taguru long-term semantic memory server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t0k0sh1/taguru.git",
    "directory": "sdk/typescript-langchain"
  },
  "keywords": ["taguru", "langchain", "llm", "memory", "rag", "retriever"],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit"
  },
  "dependencies": {
    "taguru": "^0.2.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0 <2.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.2",
    "@types/node": "^20.14.0",
    "eslint": "^10.7.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.2.0",
    "vitest": "^4.1.10"
  }
}
