{
  "name": "taguru",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client SDK for the Taguru long-term semantic memory server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t0k0sh1/taguru.git",
    "directory": "sdk/typescript"
  },
  "keywords": [
    "taguru",
    "llm",
    "memory",
    "rag",
    "knowledge-graph"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/testing.ts --format esm,cjs --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "check:surface": "tsx scripts/check-surface.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "tsup": "^8.2.0",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.2.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
